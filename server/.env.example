MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
PORT=5004
JWT_SECRET=your_strong_random_secret_here

# ─── Google Calendar / Meet Integration ───────────────────────────────────────
# Step-by-step setup:
#
# 1. Go to https://console.cloud.google.com and create a project
# 2. Enable the "Google Calendar API" in APIs & Services > Library
# 3. Go to IAM & Admin > Service Accounts > Create Service Account
# 4. Click the service account > Keys tab > Add Key > JSON
#    Save the downloaded JSON file securely (do NOT commit it)
# 5. For Google Workspace users (required for hangoutsMeet links):
#    a. Go to Admin Console (admin.google.com) > Security > API Controls
#    b. Under "Domain-wide delegation", add your service account's client ID
#    c. Grant scope: https://www.googleapis.com/auth/calendar
# 6. Copy values from the downloaded JSON into the variables below
# 7. Set GOOGLE_SUBJECT_EMAIL to a real Google Workspace user in your org
#    (the service account will act on their behalf to create calendar events)
# ──────────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SUBJECT_EMAIL=your-admin-user@yourcompany.com
GOOGLE_CALENDAR_ID=primary
